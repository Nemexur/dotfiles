#!/bin/sh
#
# Helper script to quickly setup project in Python

source $HOME/.dotfiles/script/prompt

setupPython() {
    info "Setup Python version and venv"
    user ' - Which python version to use?'
    read -e python_version
    # Setup PyEnv
    pyenv install -s $python_version
    pyenv local $python_version
    # Create Virtual Env
    python -m venv venv
}


setupRequirements() {
    # Activate venv
    source venv/bin/activate
    # Adding requiretments for python project and saving it to txt
    if [ -d requirements.txt ] ; then
        info "requirements.txt already exists"
        read -p "Create new requirements? y/n " -n 1 -r
        echo ''
        if [[ $REPLY =~ ^[Yy]$ ]]; then
            rm -rf requirements.txt
            touch requirements.txt
        fi
    else
        rm -rf requirements.txt
        touch requirements.txt
    fi
    user "Enter python project packages:"
    while read -r package
    do
        # break if the line is empty
        [ -z "$package" ] && break
        echo "$package" >> "requirements.txt"
    done
    # Load them
    pip install -r requirements.txt
}


setupJupyter() {
    read -p "Do you want to setup Jupyter and IPython for your project? y/n " -n 1 -r
    echo ''
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        source venv/bin/activate
        pip install ipython jupyterlab
        pip install ipykernel
        python -m ipykernel install --user --name venv --display-name `echo ${PWD##*/}`-venv
        success "Successfully configured Jupyter and IPython..."
    else
        info "You chose not to Jupyter and IPython."
    fi
}


setupVSCodeSettings() {
    # Optional setup of settings json
    # Whether to use default or not
    # And change venv path in it
    read -p "Do you want to use default VSCode settings.json? y/n " -n 1 -r
    echo ''
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        mkdir -p .vscode
        cp $HOME/.dotfiles/vscode/python_project_settings.json .vscode/settings.json
        # Install flake8 for linting
        source venv/bin/activate
        pip install flake8
    else
        info "You chose to setup cusom VSCode settings.json."
        mkdir -p .vscode
        touch .vscode/settings.json
    fi
}


setupPython
setupRequirements
setupJupyter
setupVSCodeSettings
